{
  "name": "cursor-agent-flow",
  "displayName": "Cursor Agent Flow",
  "description": "Schedule and orchestrate Cursor AI agents with cron schedules and multi-step workflows",
  "version": "1.0.1",
  "publisher": "longqiu-shop",
  "repository": {
    "type": "git",
    "url": "https://github.com/longqiu-shop/cursor-agent-flow-extension.git"
  },
  "homepage": "https://github.com/longqiu-shop/cursor-agent-flow-extension#readme",
  "bugs": {
    "url": "https://github.com/longqiu-shop/cursor-agent-flow-extension/issues"
  },
  "engines": {
    "vscode": "^1.74.0"
  },
  "icon": "icon.png",
  "categories": [
    "Other",
    "Machine Learning"
  ],
  "keywords": [
    "cursor",
    "ai",
    "agent",
    "workflow",
    "scheduler",
    "automation",
    "cron",
    "fanout"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "packageManager": "pnpm@10.28.0",
  "contributes": {
    "commands": [
      {
        "command": "cursorAgentFlow.add",
        "title": "Cursor Agent Flow: Add Schedule",
        "icon": "$(add)"
      },
      {
        "command": "cursorAgentFlow.runNow",
        "title": "Cursor Agent Flow: Run Now",
        "icon": "$(play)"
      },
      {
        "command": "cursorAgentFlow.edit",
        "title": "Cursor Agent Flow: Edit"
      },
      {
        "command": "cursorAgentFlow.enable",
        "title": "Cursor Agent Flow: Enable"
      },
      {
        "command": "cursorAgentFlow.disable",
        "title": "Cursor Agent Flow: Disable"
      },
      {
        "command": "cursorAgentFlow.viewRuns",
        "title": "Cursor Agent Flow: View Run History"
      },
      {
        "command": "cursorAgentFlow.viewWorkflowRuns",
        "title": "Cursor Agent Flow: View Active Workflow Runs",
        "icon": "$(list-tree)"
      },
      {
        "command": "cursorAgentFlow.startAgenticWorkflow",
        "title": "Cursor Agent Flow: Start Agentic Workflow"
      },
      {
        "command": "cursorAgentFlow.inspectWorkflowRun",
        "title": "Cursor Agent Flow: Inspect Workflow Run"
      },
      {
        "command": "cursorAgentFlow.openWorkflowRunFolder",
        "title": "Cursor Agent Flow: Open Workflow Run Folder"
      },
      {
        "command": "cursorAgentFlow.cancelWorkflowRun",
        "title": "Cursor Agent Flow: Cancel Workflow Run"
      },
      {
        "command": "cursorAgentFlow.reloadCommands",
        "title": "Cursor Agent Flow: Reload Commands",
        "icon": "$(refresh)"
      },
      {
        "command": "cursorAgentFlow.testExecution",
        "title": "Cursor Agent Flow: Test Execution"
      }
    ],
    "views": {
      "explorer": [
        {
          "id": "cursorAgentFlow",
          "name": "Cursor Agent Flow",
          "when": "true"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "cursorAgentFlow.add",
          "when": "view == cursorAgentFlow",
          "group": "navigation"
        },
        {
          "command": "cursorAgentFlow.runNow",
          "when": "view == cursorAgentFlow",
          "group": "navigation"
        },
        {
          "command": "cursorAgentFlow.viewWorkflowRuns",
          "when": "view == cursorAgentFlow",
          "group": "navigation"
        },
        {
          "command": "cursorAgentFlow.startAgenticWorkflow",
          "when": "view == cursorAgentFlow",
          "group": "navigation"
        },
        {
          "command": "cursorAgentFlow.reloadCommands",
          "when": "view == cursorAgentFlow",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "cursorAgentFlow.runNow",
          "when": "view == cursorAgentFlow && viewItem == schedule-enabled",
          "group": "inline"
        },
        {
          "command": "cursorAgentFlow.runNow",
          "when": "view == cursorAgentFlow && viewItem == schedule-disabled",
          "group": "inline"
        },
        {
          "command": "cursorAgentFlow.edit",
          "when": "view == cursorAgentFlow && (viewItem == schedule-enabled || viewItem == schedule-disabled)",
          "group": "1_actions"
        },
        {
          "command": "cursorAgentFlow.enable",
          "when": "view == cursorAgentFlow && viewItem == schedule-disabled",
          "group": "2_toggle"
        },
        {
          "command": "cursorAgentFlow.disable",
          "when": "view == cursorAgentFlow && viewItem == schedule-enabled",
          "group": "2_toggle"
        },
        {
          "command": "cursorAgentFlow.viewRuns",
          "when": "view == cursorAgentFlow && (viewItem == schedule-enabled || viewItem == schedule-disabled)",
          "group": "3_history"
        },
        {
          "command": "cursorAgentFlow.inspectWorkflowRun",
          "when": "view == cursorAgentFlow && (viewItem == workflow-run || viewItem == workflow-run-cancellable || viewItem == workflow-step)",
          "group": "1_workflow"
        },
        {
          "command": "cursorAgentFlow.openWorkflowRunFolder",
          "when": "view == cursorAgentFlow && (viewItem == workflow-run || viewItem == workflow-run-cancellable || viewItem == workflow-step)",
          "group": "1_workflow"
        },
        {
          "command": "cursorAgentFlow.cancelWorkflowRun",
          "when": "view == cursorAgentFlow && viewItem == workflow-run-cancellable",
          "group": "2_workflow"
        }
      ]
    },
    "configuration": {
      "title": "Cursor Agent Flow",
      "properties": {
        "cursorAgentFlow.additionalCommandDirectories": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Additional directories to search for command files (.md, .json, .yaml). Supports absolute paths, relative paths, and ~ for home directory."
        },
        "cursorAgentFlow.additionalSkillsDirectories": {
          "type": "array",
          "items": { "type": "string" },
          "default": [],
          "description": "Additional directories to search for skills (subdirs with SKILL.md or .md)."
        },
        "cursorAgentFlow.additionalAgentsDirectories": {
          "type": "array",
          "items": { "type": "string" },
          "default": [],
          "description": "Additional directories to search for agent/subagent definitions (.md, .json, .yaml). create-subagent skill writes to .cursor/agents."
        },
        "cursorAgentFlow.additionalMcpDirectories": {
          "type": "array",
          "items": { "type": "string" },
          "default": [],
          "description": "Additional Cursor MCP descriptor directories to include in tool inventory. Each directory should contain server subdirectories with tools/*.json descriptors."
        }
      }
    }
  },
  "scripts": {
    "clean": "node -e \"require('fs').rmSync('out', { recursive: true, force: true })\"",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "bundle": "esbuild src/extension.ts --bundle --platform=node --format=cjs --external:vscode --outfile=out/extension.js --sourcemap",
    "pretest": "pnpm run clean && pnpm run compile && pnpm run lint",
    "lint": "eslint src --ext ts",
    "test": "node --test out/agentChat/*.test.js out/workflow/*.test.js out/ui/*.test.js out/execution/*.test.js",
    "coverage": "pnpm run clean && pnpm run compile && node --test --experimental-test-coverage --test-coverage-lines=80 --test-coverage-branches=70 --test-coverage-functions=75 out/agentChat/*.test.js out/workflow/*.test.js out/ui/*.test.js out/execution/*.test.js",
    "package": "vsce package --no-dependencies",
    "prepackage": "pnpm run clean && pnpm run compile && pnpm run bundle",
    "publish:openvsx": "ts-node scripts/publish-cli.ts",
    "publish:automate": "playwright test scripts/publish-to-openvsx.ts",
    "publish:mcp": "ts-node scripts/publish-with-mcp.ts"
  },
  "dependencies": {
    "cron-parser": "^4.9.0",
    "gray-matter": "^4.0.3",
    "js-yaml": "^4.1.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.19.30",
    "@types/uuid": "^9.0.8",
    "@types/vscode": "^1.74.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@vscode/vsce": "^2.22.0",
    "esbuild": "^0.28.0",
    "eslint": "^8.0.0",
    "playwright": "^1.57.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.0.0"
  }
}
